# 主控Bot配置
MASTER_BOT_TOKEN=your_master_bot_token_here

# 数据库配置
DATABASE_PATH=./data/master.db

# 加密密钥（32字节，用于加密敏感信息）
ENCRYPTION_KEY=your_32_byte_encryption_key_here!!

# 服务器端口（用于易支付回调）
SERVER_PORT=8080

# 默认AI配置（管理员可在Bot中修改）
DEFAULT_AI_ENDPOINT=https://api.openai.com/v1/chat/completions
DEFAULT_AI_KEY=your_default_ai_key_here
DEFAULT_AI_MODEL=gpt-3.5-turbo

# 易支付配置（管理员可在Bot中修改）
# EPAY_API_URL=
# EPAY_MERCHANT_ID=
# EPAY_MERCHANT_KEY=
